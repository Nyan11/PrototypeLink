{ #category : 'initialization' }
ProliExSimplierExample >> initialize [

	super initialize.
	self constraintsDo: [ :c |
			c horizontal matchParent.
			c vertical matchParent ].
	self addChildren: self class pyramidView.
	self getScheduleListElement nodeBuilder: [ :node :dataItem :holder |
			node addChild: (ToLabeledIcon new
					 label: (ToLabel new
							  text: dataItem prettyPrintForList;
							  yourself);
					 icon: (ToElement new
							  extent: 25 @ 25;
							  background: dataItem statusColor;
							  yourself);
					 startInterspace: 3;
					 yourself) ].
	self getStatusListElement nodeBuilder: [ :node :dataItem :holder |
			node addChild: (ToLabeledIcon new
					 label: (ToLabel new
							  text: dataItem prettyPrintForList;
							  yourself);
					 icon: (ToElement new
							  extent: 25 @ 25;
							  background: dataItem statusColor;
							  yourself);
					 startInterspace: 3;
					 yourself) ].
	self getCenterElement background:
		(BlImageBackground image: (self class trainForm magnifyBy: 6.4)).
	self getRaiseButtonElement enabled: false.
	self initializeExample.
	self initializeRequirements
]

{ #category : 'initialization' }
ProliExSimplierExample >> initializeExample [

	self status: {
			ProliExSimplierSensorModel name: 'Liquid Pressure' value: '5 MPa'.
			ProliExSimplierSensorModel name: 'Liquid Temperature' value: '55 °C'.
			ProliExSimplierSensorModel name: 'Radar' value: 'Operational' }.
	self schedule:
		(((1 to: 20) collect: [ :i | ProliExSimplierTrainModel new ]) sort: [
			 :a
			 :b | a time < b time ])
]

{ #category : 'initialization' }
ProliExSimplierExample >> initializeRequirements [

	self getEmergencyButtonElement proliAnnotedBy: ProliExSimplierRequirements uxRequirement1.
	self getCenterElement proliAnnotedBy: ProliExSimplierRequirements uxRequirement2.
	self getStatusListElement proliAnnotedBy: ProliExSimplierRequirements capellaFunction1.
	self getScheduleListElement proliAnnotedBy: ProliExSimplierRequirements capellaFunction2.
	self getDropButtonElement proliAnnotedBy: ProliExSimplierRequirements capellaFunction3.
	self getRaiseButtonElement proliAnnotedBy: ProliExSimplierRequirements capellaFunction3.
	self getEmergencyButtonElement proliAnnotedBy: ProliExSimplierRequirements capellaFunction4.
	
]

{ #category : 'accessing' }
ProliExSimplierExample >> schedule [

	^ schedule
]

{ #category : 'accessing' }
ProliExSimplierExample >> schedule: anObject [

	schedule := anObject.
	self getScheduleListElement dataAccessor addAll: anObject
]

{ #category : 'accessing' }
ProliExSimplierExample >> status [

	^ status
]

{ #category : 'accessing' }
ProliExSimplierExample >> status: anObject [

	status := anObject.
	self getStatusListElement dataAccessor addAll: anObject
